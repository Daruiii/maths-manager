{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "prettier:fix": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "prettier:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "tsc": "tsc --noEmit",
    "test:react": "vitest run",
    "test:react:watch": "vitest",
    "precommit": "npm run tsc && npm run lint && npm run prettier:check && npm run test:react && php artisan config:clear && php artisan test --env=testing"
  },
