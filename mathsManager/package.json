    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^28.0.0",
    "laravel-vite-plugin": "^1.0",
    "postcss": "^8.4.31",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sass": "^1.71.1",
    "tailwindcss": "^3.1.0",
    "typescript": "^5.9.3",
