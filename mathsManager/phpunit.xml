<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
    <env name="APP_ENV" value="testing" force="true"/>
    <env name="APP_DEBUG" value="true" force="true"/>
    <env name="DB_CONNECTION" value="mariadb" force="true"/>
    <env name="DB_HOST" value="127.0.0.1" force="true"/>
    <env name="DB_PORT" value="3307" force="true"/>
    <env name="DB_DATABASE" value="mathsmanager_test" force="true"/>
    <env name="DB_USERNAME" value="root" force="true"/>
    <env name="DB_PASSWORD" value="root" force="true"/>
    <env name="APP_MAINTENANCE_DRIVER" value="file" force="true"/>
    <env name="BCRYPT_ROUNDS" value="4" force="true"/>
    <env name="PULSE_ENABLED" value="false" force="true"/>
    <env name="TELESCOPE_ENABLED" value="false" force="true"/>
    </php>
</phpunit>
